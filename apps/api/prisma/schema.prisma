generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  phone            String    @unique
  role             UserRole  @default(CLIENT)
  clientTrustScore Float     @default(0) @map("client_trust_score")
  clientReviewCount Int      @default(0) @map("client_review_count")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  authIdentities AuthIdentity[]
  vendor         Vendor?
  clientProfile  ClientProfile?
  reviews        Review[]
  refreshTokens  RefreshToken[]
  budgets        Budget[]
  guestLists     GuestList[]
  inquiries      Inquiry[]
  invoices       Invoice[]
  clientReviews  ClientReview[]

  @@map("users")
}

enum UserRole {
  CLIENT
  VENDOR
  ADMIN

  @@map("user_role")
}

// ─── Auth Identities ─────────────────────────────────────────────────────────

model AuthIdentity {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String       @map("user_id") @db.Uuid
  provider   AuthProvider
  providerId String       @map("provider_id")
  createdAt  DateTime     @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@map("auth_identities")
}

enum AuthProvider {
  PHONE
  GOOGLE
  FACEBOOK

  @@map("auth_provider")
}

// ─── OTP Requests ────────────────────────────────────────────────────────────

model OtpRequest {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  phone     String
  codeHash  String   @map("code_hash")
  attempts  Int      @default(0)
  expiresAt DateTime @map("expires_at")
  verified  Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([phone, createdAt])
  @@map("otp_requests")
}

// ─── Refresh Tokens ──────────────────────────────────────────────────────────

model RefreshToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ─── Vendors ─────────────────────────────────────────────────────────────────

model Vendor {
  id                   String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId               String       @unique @map("user_id") @db.Uuid
  slug                 String       @unique
  businessName         String       @map("business_name")
  category             VendorCategory
  description          String
  area                 String
  address              String?
  priceFrom            Decimal?     @map("price_from") @db.Decimal(10, 2)
  priceTo              Decimal?     @map("price_to") @db.Decimal(10, 2)
  whatsappNumber       String?      @map("whatsapp_number")
  instagramHandle      String?      @map("instagram_handle")
  coverImageUrl        String?      @map("cover_image_url")
  status               VendorStatus @default(DRAFT)
  avgRating            Float        @default(0) @map("avg_rating")
  reviewCount          Int          @default(0) @map("review_count")
  profileCompleteScore Float        @default(0) @map("profile_complete_score")
  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @updatedAt @map("updated_at")
  deletedAt            DateTime?    @map("deleted_at")

  subscriptionTier SubscriptionTier @default(FREE) @map("subscription_tier")

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  portfolio        VendorPortfolio[]
  reviews          Review[]
  disputes         Dispute[]
  listings         Listing[]
  inquiries        Inquiry[]
  invoices         Invoice[]
  invoiceBranding  InvoiceBranding?
  clientReviews    ClientReview[]

  @@index([status, avgRating])
  @@index([category, area])
  @@map("vendors")
}

enum VendorStatus {
  DRAFT
  PENDING
  ACTIVE
  CHANGES_REQUESTED
  SUSPENDED

  @@map("vendor_status")
}

enum VendorCategory {
  CATERER
  PHOTOGRAPHER
  VIDEOGRAPHER
  VENUE
  DECORATOR
  MC
  DJ
  MAKEUP_ARTIST
  PLANNER
  OTHER

  @@map("vendor_category")
}

// ─── Vendor Portfolio ────────────────────────────────────────────────────────

model VendorPortfolio {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vendorId  String    @map("vendor_id") @db.Uuid
  mediaUrl  String    @map("media_url")
  mediaType MediaType @map("media_type")
  caption   String?
  sortOrder Int       @default(0) @map("sort_order")
  createdAt DateTime  @default(now()) @map("created_at")

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@map("vendor_portfolio")
}

enum MediaType {
  IMAGE
  VIDEO

  @@map("media_type")
}

// ─── Reviews ─────────────────────────────────────────────────────────────────

model Review {
  id        String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vendorId  String       @map("vendor_id") @db.Uuid
  clientId  String       @map("client_id") @db.Uuid
  listingId String?      @map("listing_id") @db.Uuid
  invoiceId String?      @map("invoice_id") @db.Uuid
  rating    Int
  body      String
  status    ReviewStatus @default(PENDING)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")
  deletedAt DateTime?    @map("deleted_at")

  vendor  Vendor       @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  client  User         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  listing Listing?     @relation(fields: [listingId], references: [id], onDelete: SetNull)
  invoice Invoice?     @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  reply   VendorReply?
  dispute Dispute?

  @@index([vendorId, status])
  @@index([listingId, status])
  @@map("reviews")
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  REMOVED

  @@map("review_status")
}

// ─── Vendor Replies ──────────────────────────────────────────────────────────

model VendorReply {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reviewId  String   @unique @map("review_id") @db.Uuid
  body      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@map("vendor_replies")
}

// ─── Disputes ────────────────────────────────────────────────────────────────

model Dispute {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reviewId     String        @unique @map("review_id") @db.Uuid
  vendorId     String        @map("vendor_id") @db.Uuid
  reason       String
  status       DisputeStatus @default(OPEN)
  adminDecision String?      @map("admin_decision")
  policyClause  String?      @map("policy_clause")
  appealReason  String?      @map("appeal_reason")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@map("disputes")
}

enum DisputeStatus {
  OPEN
  DECIDED
  APPEALED
  CLOSED

  @@map("dispute_status")
}

// ─── Client Reviews (vendor → client) ────────────────────────────────────────

model ClientReview {
  id        String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vendorId  String       @map("vendor_id") @db.Uuid
  clientId  String       @map("client_id") @db.Uuid
  invoiceId String       @unique @map("invoice_id") @db.Uuid
  rating    Int
  body      String?
  status    ReviewStatus @default(PENDING)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  vendor  Vendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  client  User    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([clientId, status])
  @@map("client_reviews")
}

// ─── Listings ────────────────────────────────────────────────────────────────

model Listing {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vendorId    String          @map("vendor_id") @db.Uuid
  listingType ListingType     @map("listing_type")
  title       String
  description String
  category    VendorCategory?
  priceFrom   Int?            @map("price_from")
  priceTo     Int?            @map("price_to")
  photos      String[]        @default([])
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  deletedAt   DateTime?       @map("deleted_at")

  avgRating   Float           @default(0) @map("avg_rating")
  reviewCount Int             @default(0) @map("review_count")

  vendor        Vendor                @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  rentalDetails ListingRentalDetails?
  reviews       Review[]
  inquiries     Inquiry[]

  @@index([vendorId, listingType])
  @@index([listingType, category])
  @@map("listings")
}

model ListingRentalDetails {
  id                String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  listingId         String         @unique @map("listing_id") @db.Uuid
  rentalCategory    RentalCategory @map("rental_category")
  quantityAvailable Int            @map("quantity_available")
  pricePerDay       Int            @map("price_per_day")
  depositAmount     Int?           @map("deposit_amount")
  deliveryOption    DeliveryOption @map("delivery_option")
  condition         RentalCondition?

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@map("listing_rental_details")
}

enum ListingType {
  SERVICE
  RENTAL

  @@map("listing_type")
}

enum RentalCategory {
  TENT
  CHAIRS_TABLES
  COOKING_EQUIPMENT
  GENERATOR
  LIGHTING
  OTHER_RENTAL

  @@map("rental_category")
}

enum DeliveryOption {
  PICKUP_ONLY
  DELIVERY_ONLY
  BOTH

  @@map("delivery_option")
}

enum RentalCondition {
  NEW
  LIKE_NEW
  GOOD
  FAIR
  POOR

  @@map("rental_condition")
}

enum SubscriptionTier {
  FREE
  PRO
  PRO_PLUS

  @@map("subscription_tier")
}

// ─── Budgets ─────────────────────────────────────────────────────────────────

model Budget {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  name        String
  totalAmount Int?      @map("total_amount")
  eventDate   DateTime? @map("event_date") @db.Date
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  items BudgetItem[]

  @@index([userId])
  @@map("budgets")
}

model BudgetItem {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  budgetId  String   @map("budget_id") @db.Uuid
  name      String
  budgeted  Int      @default(0)
  actual    Int      @default(0)
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  budget Budget @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@index([budgetId])
  @@map("budget_items")
}

// ─── Guest Lists ─────────────────────────────────────────────────────────────

model GuestList {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  name         String
  eventDate    DateTime? @map("event_date") @db.Date
  plannedCount Int?      @map("planned_count")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  guests Guest[]

  @@index([userId])
  @@map("guest_lists")
}

model Guest {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  guestListId    String      @map("guest_list_id") @db.Uuid
  name           String
  phone          String?
  status         GuestStatus @default(PENDING)
  invitationSent Boolean     @default(false) @map("invitation_sent")
  plusOne        Boolean     @default(false) @map("plus_one")
  plusOneName    String?     @map("plus_one_name")
  notes          String?
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  guestList GuestList @relation(fields: [guestListId], references: [id], onDelete: Cascade)

  @@index([guestListId])
  @@map("guests")
}

enum GuestStatus {
  PENDING
  INVITED
  COMING
  NOT_COMING

  @@map("guest_status")
}

// ─── Inquiries ────────────────────────────────────────────────────────────────

model Inquiry {
  id        String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId  String        @map("client_id") @db.Uuid
  vendorId  String        @map("vendor_id") @db.Uuid
  listingId String?       @map("listing_id") @db.Uuid
  source    InquirySource
  message   String?
  notes     String?
  status    InquiryStatus @default(NEW)
  invoiceId String?       @unique @map("invoice_id") @db.Uuid
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  client  User     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  vendor  Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  listing Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)
  invoice Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([clientId, status])
  @@index([vendorId, status])
  @@map("inquiries")
}

enum InquiryStatus {
  NEW
  CONTACTED
  BOOKED
  COMPLETED
  CANCELLED

  @@map("inquiry_status")
}

enum InquirySource {
  WHATSAPP_BUTTON
  ENQUIRY_FORM
  MANUAL

  @@map("inquiry_source")
}

// ─── Invoices ────────────────────────────────────────────────────────────────

model Invoice {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vendorId          String        @map("vendor_id") @db.Uuid
  clientId          String?       @map("client_id") @db.Uuid
  invoiceNumber     String        @unique @map("invoice_number")
  status            InvoiceStatus @default(DRAFT)
  clientName        String        @map("client_name")
  clientPhone       String?       @map("client_phone")
  clientEmail       String?       @map("client_email")
  eventDate         DateTime?     @map("event_date") @db.Date
  eventLocation     String?       @map("event_location")
  notes             String?
  subtotalKobo      Int           @default(0) @map("subtotal_kobo")
  discountKobo      Int           @default(0) @map("discount_kobo")
  totalKobo         Int           @default(0) @map("total_kobo")
  sentAt            DateTime?     @map("sent_at")
  viewedAt          DateTime?     @map("viewed_at")
  confirmedAt       DateTime?     @map("confirmed_at")
  completedAt       DateTime?     @map("completed_at")
  reviewNudgeSentAt DateTime?     @map("review_nudge_sent_at")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  vendor       Vendor        @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  client       User?         @relation(fields: [clientId], references: [id], onDelete: SetNull)
  inquiry      Inquiry?
  items        InvoiceItem[]
  reviews      Review[]
  clientReview ClientReview?

  @@index([vendorId, status])
  @@index([eventDate, status])
  @@map("invoices")
}

model InvoiceItem {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceId     String   @map("invoice_id") @db.Uuid
  description   String
  quantity      Int
  unitPriceKobo Int      @map("unit_price_kobo")
  totalKobo     Int      @map("total_kobo")
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_items")
}

enum InvoiceStatus {
  DRAFT
  SENT
  VIEWED
  CONFIRMED
  COMPLETED
  CANCELLED

  @@map("invoice_status")
}

// ─── Invoice Branding ─────────────────────────────────────────────────────────

model InvoiceBranding {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vendorId    String   @unique @map("vendor_id") @db.Uuid
  logoUrl     String?  @map("logo_url")
  accentColor String   @default("#16a34a") @map("accent_color")
  tagline     String?
  footerText  String?  @map("footer_text")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@map("invoice_branding")
}

// ─── Client Profiles ─────────────────────────────────────────────────────────

model ClientProfile {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @unique @map("user_id") @db.Uuid
  displayName String   @map("display_name")
  email       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("client_profiles")
}

// ─── Admin Log ───────────────────────────────────────────────────────────────

model AdminLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  adminId    String   @map("admin_id") @db.Uuid
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id") @db.Uuid
  details    Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([adminId])
  @@map("admin_log")
}
